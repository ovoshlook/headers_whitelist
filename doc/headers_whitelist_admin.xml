<!-- Module User's Guide -->

<chapter>

    <title>&adminguide;</title>

    <section>
        <title>Overview</title>
        <para>
            This module removes SIP headers from incoming messages unless they are
            part of the module whitelist.
        </para>
        <para>
            Headers required by RFC 3261 (Via, To, From, CSeq, Call-ID) are always
            kept. Additional groups of headers can be enabled or disabled through
            module parameters.
        </para>
        <para>
            Custom header names can be whitelisted with the
            <varname>keep_header</varname> parameter.
        </para>
    </section>

    <section>
        <title>Dependencies</title>
        <section>
            <title>&kamailio; Modules</title>
            <para>
                The following modules must be loaded before this module:
                <itemizedlist>
                    <listitem>
                        <para><emphasis>None</emphasis>.</para>
                    </listitem>
                </itemizedlist>
            </para>
        </section>
        <section>
            <title>External Libraries or Applications</title>
            <para>
                The following libraries or applications must be installed before
                running &kamailio; with this module loaded:
                <itemizedlist>
                    <listitem>
                        <para><emphasis>None</emphasis>.</para>
                    </listitem>
                </itemizedlist>
            </para>
        </section>
    </section>

    <section>
        <title>Parameters</title>

        <section id="headers_whitelist.p.keep_described_rfc3261">
            <title><varname>keep_described_rfc3261</varname> (int)</title>
            <para>
                Enable or disable keeping of headers described (but not required)
                by RFC 3261, for example Contact, Max-Forwards, Route,
                Record-Route, Content-*, Authorization and related headers.
            </para>
            <para>
                If this parameter is set to 0, specific headers can still be kept
                with <varname>keep_header</varname>.
            </para>
            <para><emphasis>Default value is 1 (enabled).</emphasis></para>
            <example>
                <title>Set <varname>keep_described_rfc3261</varname> parameter</title>
                <programlisting format="linespecific">
...
modparam("headers_whitelist", "keep_described_rfc3261", 1)
...
</programlisting>
            </example>
        </section>

